{
  "manifest_version": 3,
  "name": "EmailDigest AI",
  "version": "1.0",
  "description": "AI-powered email summaries inside Gmail",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://emaildigest-kappa.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    },
    {
      "matches": ["https://emaildigest-kappa.vercel.app/*"],
      "js": ["auth-listener.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}